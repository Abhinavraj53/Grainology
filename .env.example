# ============================================
# Grainology Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to Git!

# ============================================
# Server Configuration
# ============================================
PORT=3001
NODE_ENV=development

# ============================================
# Database Configuration
# ============================================
# Local MongoDB
MONGODB_URI=mongodb://localhost:27017/grainology

# MongoDB Atlas (Production)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/grainology?retryWrites=true&w=majority
# Optional local fallback when mongodb+srv DNS lookup fails on a machine/network.
# MONGODB_DIRECT_URI=mongodb://username:password@host1:27017,host2:27017,host3:27017/grainology?ssl=true&authSource=admin&replicaSet=your-replica-set&retryWrites=true&w=majority
# Set true locally to try MONGODB_DIRECT_URI before the mongodb+srv URI.
# MONGODB_PREFER_DIRECT=true

# ============================================
# JWT Authentication
# ============================================
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d
# Secret used to encrypt/decrypt original passwords for Super Admin view/email.
# Keep this long and private in production.
PASSWORD_VIEW_SECRET=change-this-password-view-secret

# ============================================
# Local Kaggle AI Release Sync
# ============================================
# Used only for local model iteration. Keep real values in .env, never commit them.
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key
KAGGLE_KERNEL_ID=jkail/grainology-state-price-forecast
# Comma-separated Kaggle dataset refs that your Kaggle account can access.
# Example: your-user/daily-commodity-prices-india,your-user/grainology-latest-data
KAGGLE_DATASET_SOURCES=
# Optional explicit dataset ref for publishing staging/kaggle-latest-data/latest_data.csv.
# If omitted, scripts try to infer the ref containing "latest-data" from KAGGLE_DATASET_SOURCES.
KAGGLE_LATEST_DATASET_ID=
LATEST_DATA_EXPORT_DIR=staging/kaggle-latest-data
LATEST_DATA_BASE_CSV=../commodity_forecasting_v36_with_arrival_csv_bundle/latest_data.csv
LATEST_DATA_MIN_BYTES=10485760
LATEST_DATA_MIN_ROWS=100000
LOCAL_KAGGLE_SYNC_MINUTES=15
LOCAL_KAGGLE_SYNC_DIR=staging
AI_PREDICTIONS_SOURCE=local_files
AI_PREDICTION_BUCKET=ai-predictions

# ============================================
# AI Auto Refresh
# ============================================
# In production, GitHub Actions runs this once daily. If you run `npm run ai:auto`
# as a long-running local watcher, this controls its polling interval.
AI_AUTO_CHECK_MINUTES=1440
AI_AUTO_MIN_STATE_CACHE_COVERAGE=0.85
AI_AUTO_STATE_DIR=staging/ai-auto-refresh
# Local testing can keep this false. Production/live Supabase release publishing needs
# Python dependencies and Supabase secrets.
AI_AUTO_PUBLISH_SUPABASE_RELEASE=false
AI_AUTO_SKIP_KAGGLE=false
# Keep true unless your installed Kaggle CLI rejects --quiet.
KAGGLE_DATASET_VERSION_QUIET=true

# ============================================
# AI Reasoning (Optional Gemini)
# ============================================
# If set, the dashboard explains forecasts in simple bullet points using Gemini.
# If omitted or Gemini fails, the backend returns a safe local fallback explanation.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest
GEMINI_ENABLE_GOOGLE_SEARCH=true
GEMINI_REASONING_CACHE_SECONDS=900
GEMINI_TIMEOUT_MS=30000

# ============================================
# Frontend URL (for CORS)
# ============================================
# Local development
FRONTEND_URL=http://localhost:5173

# Production (set to your deployed frontend origin)
# FRONTEND_URL=https://your-frontend.onrender.com

# ============================================
# Backend API URL (frontend - VITE_API_URL)
# ============================================
# Local development
# VITE_API_URL=http://localhost:3001/api

# Production (Render backend)
# VITE_API_URL=https://grainology-project.onrender.com/api

# ============================================
# Sandbox KYC API (Aadhaar Verification)
# ============================================
# Get your API keys from: https://developer.sandbox.co.in/
SANDBOX_API_KEY=your_sandbox_api_key_here
SANDBOX_API_SECRET=your_sandbox_api_secret_here
SANDBOX_BASE_URL=https://api.sandbox.co.in
SANDBOX_API_VERSION=1.0

# ============================================
# Cashfree KYC API (Optional - for PAN/GST/CIN verification)
# ============================================
# Get your credentials from: https://www.cashfree.com/
CASHFREE_CLIENT_ID=your_cashfree_client_id_here
CASHFREE_CLIENT_SECRET=your_cashfree_client_secret_here
CASHFREE_BASE_URL=https://api.cashfree.com

# ============================================
# Notes
# ============================================
# 1. Always keep your .env file secure and never commit it to Git
# 2. For production, set NODE_ENV=production
# 3. Use strong, unique values for JWT_SECRET in production
# 4. Update FRONTEND_URL to match your production domain
# 5. For MongoDB Atlas, ensure your IP is whitelisted

# ============================================
# Brevo (Email) - use either REST API or SMTP
# ============================================
# On Render/cloud: prefer BREVO_API_KEY (REST) – SMTP port 587 often blocked (ETIMEDOUT).
# REST API key (Brevo → API Keys): preferred for production
# BREVO_API_KEY=xkeysib-your-api-key
# SMTP (Brevo → SMTP & API): for local dev; port 587 may timeout on Render
# BREVO_SMTP_USER=a1e08c001@smtp-brevo.com
# BREVO_SMTP_KEY=xsmtpsib-your-smtp-key
# BREVO_FROM_EMAIL=noreply@yourdomain.com
# BREVO_FROM_NAME=Grainology

# ============================================
# Supabase Configuration
# ============================================
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
AI_RELEASE_CACHE_TTL_SECONDS=300
AGGREGATION_METHOD=median
