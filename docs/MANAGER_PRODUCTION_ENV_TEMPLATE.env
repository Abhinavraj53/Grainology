# Grainology production handoff template
# Fill real values privately. Do not commit a filled copy.
#
# IMPORTANT:
# - Render backend env uses the RENDER_BACKEND section.
# - Render frontend env uses the RENDER_FRONTEND section.
# - GitHub Actions secrets use the GITHUB_ACTIONS section.
# - This is one handoff file for the manager, but each platform still needs the
#   values pasted into its own dashboard.

# =============================================================================
# RENDER_BACKEND
# =============================================================================
NODE_ENV=production
PORT=3001

MONGODB_URI=<mongodb_atlas_connection_string>
JWT_SECRET=<strong_random_secret>
PASSWORD_VIEW_SECRET=<strong_random_secret>

FRONTEND_URL=https://grainologyagri.com
CORS_ORIGINS=https://grainologyagri.com,https://www.grainologyagri.com

SUPABASE_URL=<supabase_project_url>
SUPABASE_SECRET_KEY=<supabase_service_role_key>
SUPABASE_SERVICE_ROLE_KEY=<supabase_service_role_key>

AI_PREDICTIONS_SOURCE=supabase_release
AI_PREDICTION_BUCKET=ai-predictions
AI_RELEASE_CACHE_TTL_SECONDS=300

MANDI_API_KEY=<data_gov_or_mandi_api_key>

GEMINI_API_KEY=<gemini_api_key>
GEMINI_MODEL=gemini-flash-lite-latest
GEMINI_ENABLE_GOOGLE_SEARCH=true
GEMINI_REASONING_CACHE_SECONDS=900
GEMINI_TIMEOUT_MS=30000

BREVO_API_KEY=<brevo_api_key>
BREVO_FROM_EMAIL=<sender_email>
BREVO_FROM_NAME=Grainology

CRON_SECRET=<strong_random_secret>

# =============================================================================
# RENDER_FRONTEND
# =============================================================================
VITE_API_URL=https://<backend-render-url>/api

# =============================================================================
# GITHUB_ACTIONS
# =============================================================================
SUPABASE_URL=<supabase_project_url>
SUPABASE_SECRET_KEY=<supabase_service_role_key>
SUPABASE_SERVICE_ROLE_KEY=<supabase_service_role_key>
AI_PREDICTION_BUCKET=ai-predictions

KAGGLE_USERNAME=sanjayj23iitk
KAGGLE_KEY=<kaggle_api_key>
KAGGLE_KERNEL_ID=sanjayj23iitk/graninology
KAGGLE_DATASET_SOURCES=khandelwalmanas/daily-commodity-prices-india,sanjayj23iitk/jkailgrainology-latest-data
KAGGLE_LATEST_DATASET_ID=sanjayj23iitk/jkailgrainology-latest-data
