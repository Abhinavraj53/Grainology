{
  "name": "grainology-backend",
  "version": "1.0.0",
  "description": "Grainology Digital Agri-Marketplace Backend API",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --ignore dist server.js",
    "dev:frontend": "vite --host",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:frontend\"",
    "build": "vite build",
    "build:frontend": "vite build",
    "preview": "vite preview",
    "test": "echo \"Error: no test specified\" && exit 1",
    "db:check": "node scripts/checkMongoConnection.js",
    "import:supply-transactions": "node scripts/importSupplyTransactions.js",
    "seed:quality-parameters": "node scripts/seedQualityParameters.js",
    "verify:quality-parameters": "node scripts/verifyQualityParameters.js",
    "seed:users": "node scripts/seedDemoUsers.js",
    "seed:data": "node scripts/seedDemoData.js",
    "seed:all": "npm run seed:users && npm run seed:data",
    "seed:super-admin": "node scripts/createSuperAdminUser.js",
    "ai:sync-local": "node scripts/syncKaggleAiReleaseLocal.js",
    "ai:sync-local:once": "node scripts/syncKaggleAiReleaseLocal.js --once",
    "ai:backfill-actuals": "node scripts/backfillAiActualsFromCache.js --apply",
    "ai:update-latest-csv": "node scripts/exportSupabaseLatestDataCsv.js",
    "ai:refresh-latest-data": "npm run ai:backfill-actuals && npm run ai:update-latest-csv",
    "ai:publish-latest-data": "node scripts/publishLatestDataCsvToKaggle.js",
    "ai:auto:once": "node scripts/autoAiRefresh.js --once",
    "ai:auto:force": "node scripts/autoAiRefresh.js --once --force",
    "ai:auto": "node scripts/autoAiRefresh.js",
    "ai:kaggle-run": "node scripts/runKaggleNotebookLocal.js",
    "ai:kaggle-run:no-sync": "node scripts/runKaggleNotebookLocal.js --no-sync"
  },
  "keywords": [
    "grainology",
    "agri-marketplace",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "@types/react-router-dom": "^5.3.3",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "cashfree-verification": "^4.0.1",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "form-data": "^4.0.5",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.344.0",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.5.0",
    "nodemailer": "^6.10.1",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.10.1",
    "recharts": "^3.6.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^10.0.3",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "nodemon": "^3.0.2",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  }
}
